{
  "name": "slidev-theme-dmml",
  "version": "0.1.4",
  "description": "A Slidev theme for the ASU Data Mining and Machine Learning Lab",
  "license": "MIT",
  "author": "Shu Wan",
  "homepage": "https://github.com/Shu-Wan/slidev-theme-dmml#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shu-Wan/slidev-theme-dmml.git"
  },
  "bugs": {
    "url": "https://github.com/Shu-Wan/slidev-theme-dmml/issues"
  },
  "keywords": [
    "slidev-theme",
    "slidev",
    "asu",
    "dmml",
    "academic"
  ],
  "engines": {
    "slidev": ">=0.49.0"
  },
  "files": [
    "layouts",
    "components",
    "styles",
    "setup",
    "assets",
    "CHANGELOG.md"
  ],
  "slidev": {
    "colorSchema": "both",
    "highlighter": "shiki",
    "defaults": {
      "fonts": {
        "sans": "Geist",
        "mono": "Geist Mono",
        "provider": "none"
      }
    }
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.1.0",
    "@fontsource-variable/geist-mono": "^5.1.0"
  },
  "devDependencies": {
    "@slidev/cli": "^52.0.0",
    "@slidev/types": "^52.0.0",
    "playwright-chromium": "^1.50.0",
    "prettier": "^3.3.3",
    "prettier-plugin-slidev": "^1.0.5",
    "slidev-addon-citations": "^0.0.13"
  },
  "scripts": {
    "dev": "slidev example.md --open",
    "build": "slidev build example.md",
    "export": "slidev export example.md",
    "format": "prettier --write \"example.md\" \"**/*.{vue,ts,css,md}\"",
    "format:check": "prettier --check \"example.md\" \"**/*.{vue,ts,css,md}\""
  }
}
